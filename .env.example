# ============================================================================
#  BO Commander — Environment Configuration
#  File:  .env
#  ============================================================================
#
#  SETUP INSTRUCTIONS
#  ──────────────────
#  1. Copy this file:        copy .env.example .env
#  2. Fill in your values    (see each section below)
#  3. Save the file          — BO Commander reads it on every launch
#  4. NEVER commit .env to Git / share it — it contains passwords & API keys
#
#  Questions?  saitejaguddanti999@gmail.com
#  LinkedIn:   https://www.linkedin.com/in/sai-teja-628082288
# ============================================================================


# ── SAP BusinessObjects Server ───────────────────────────────────────────────
#
#  BO_HOST     → hostname or IP of your BO server
#               Examples:  bo-server.mycompany.com   |   192.168.1.50
#
#  BO_PORT     → CMS port (default 6405 for BI 4.x)
#               Check in CMC → Servers → Central Management Server → Properties
#
#  BO_USERNAME → BO admin username (Enterprise auth)
#               Use an account with at minimum "View Objects" + "Log On" rights
#
#  BO_PASSWORD → Password for the account above
#
#  BO_AUTH_TYPE options:
#               secEnterprise  → SAP BO built-in accounts (most common)
#               secWinAD       → Windows Active Directory SSO
#               secLDAP        → LDAP directory
#               secSAPR3       → SAP system authentication
#
BO_HOST=your-bo-server.company.com
BO_PORT=6405
BO_USERNAME=Administrator
BO_PASSWORD=your_password_here
BO_AUTH_TYPE=secEnterprise


# ── SAP BO REST API ───────────────────────────────────────────────────────────
#
#  BO_REST_PORT → port for the RESTful web services (biprws)
#                 Default is 6405 (same as CMS) for BI 4.x
#                 Some installations use 8080 (Tomcat) — check with your admin
#
#  BO_REST_PROTOCOL → http or https
#                     Use https if your Tomcat/IIS is SSL-enabled
#
BO_REST_PORT=6405
BO_REST_PROTOCOL=http


# ── AI Model API Keys ─────────────────────────────────────────────────────────
#
#  GEMINI_API_KEY → Powers AI Sentinel, AI Assistant, and Self Healing
#
#  How to get a free Gemini API key:
#    1. Go to https://makersuite.google.com/app/apikey
#    2. Sign in with a Google account
#    3. Click "Create API key"
#    4. Copy the key (starts with  AIzaSy...)
#    5. Paste it below
#
#  The free tier (Gemini 1.5 Flash) is sufficient for normal admin use.
#  Without this key, all non-AI features still work normally.
#
GEMINI_API_KEY=AIzaSy_paste_your_key_here


# ── License ───────────────────────────────────────────────────────────────────
#
#  LICENSE_KEY → your 30-day activation key
#                Obtained from:  saitejaguddanti999@gmail.com
#                               or LinkedIn (see link above)
#
#  Keys expire after 30 days. Contact the developer before expiry to renew.
#  Renewal is FREE — just send a message with your name and machine name.
#
LICENSE_KEY=BOCMD-XXXX-XXXX-XXXXX


# ── Notification / Email Alerts (optional) ───────────────────────────────────
#
#  FORMSPREE_FORM_ID → If you want BO Commander to email you on:
#                       • user activations
#                       • license renewals
#                       • each tool launch
#
#  How to set up (free):
#    1. Go to https://formspree.io and create a free account
#    2. Create a new form (any name)
#    3. Copy the Form ID from the URL  (e.g.  xnqkjbzp)
#    4. Paste it below
#    5. In core/license_manager.py, also set FORMSPREE_FORM_ID = "xnqkjbzp"
#
#  If left as "YOUR_FORM_ID_HERE" — email notifications are silently skipped.
#
FORMSPREE_FORM_ID=YOUR_FORM_ID_HERE


# ── Application Behaviour (optional tweaks) ───────────────────────────────────
#
#  AUTO_OPEN_BROWSER → Set to "true" to auto-open the product info page
#                       (localhost:8765) in your browser on every launch
#
#  WEB_PORT          → Port for the local product info web server
#                       Default is 8765. Change if that port is in use.
#
AUTO_OPEN_BROWSER=false
WEB_PORT=8765


# ============================================================================
#  QUICK REFERENCE — Most common configuration
# ============================================================================
#
#  Minimal working setup (fill these 4 lines, everything else is optional):
#
#    BO_HOST=your-bo-server.company.com
#    BO_USERNAME=Administrator
#    BO_PASSWORD=yourpassword
#    GEMINI_API_KEY=AIzaSy...
#
#  Then run:   python bo_commander.py
#
# ============================================================================
